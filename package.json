{
  "name": "agenda-facil",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format cjs --clean --minify --platform node",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint .",
    "seed": "tsx prisma/seed.ts",
    "install:gemini": "npm install @google/gemini-cli@0.43.0 --save-dev",
    "gemini": "npx @google/gemini-cli",
    "gemini:auth": "npx @google/gemini-cli auth login"
  },
  "devDependencies": {
    "@google/gemini-cli": "0.43.0",
    "@playwright/test": "^1.60.0",
    
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/pino-pretty": "^4.7.5",
    "eslint": "^10.4.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "pg": "^8.21.0"
  }
}
